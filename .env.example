# Copy to .env.local and fill in. Only publishable/anon values belong here —
# NEXT_PUBLIC_* is compiled into the browser bundle. Never put the service-role
# key or the JWT secret in this file.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
